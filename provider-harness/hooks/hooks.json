{
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc '\"${CLAUDE_PLUGIN_ROOT}/scripts/harvest-detect.sh\"'",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc '\"${CLAUDE_PLUGIN_ROOT}/scripts/harvest-nudge.sh\"'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
